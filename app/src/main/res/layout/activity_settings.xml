<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgPrimary"
    android:orientation="vertical">

    <!-- Toolbar -->
    <io.agents.pokeclaw.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="44dp" />

    <!-- 滚动内容 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="8dp">

            <!-- 小米/红米手机提示 -->
            <LinearLayout
                android:id="@+id/xiaomiTipLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/xiaomi_tip_title"
                    android:textColor="#E65100"
                    android:textSize="16dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/xiaomi_tip_desc"
                    android:textColor="#BF360C"
                    android:textSize="13dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/xiaomi_tip_steps"
                    android:textColor="#D84315"
                    android:textSize="12dp" />

                <TextView
                    android:id="@+id/btnOpenAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_edit_text"
                    android:gravity="center"
                    android:text="@string/xiaomi_tip_button"
                    android:textColor="#E65100"
                    android:textSize="14dp" />

            </LinearLayout>

            <!-- 权限分组 -->
            <io.agents.pokeclaw.widget.MenuGroup
                android:id="@+id/permissionsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <!-- 模型分组 -->
            <io.agents.pokeclaw.widget.MenuGroup
                android:id="@+id/modelGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Appearance -->
            <io.agents.pokeclaw.widget.MenuGroup
                android:id="@+id/appearanceGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Tools -->
            <io.agents.pokeclaw.widget.MenuGroup
                android:id="@+id/toolsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Remote Control -->
            <io.agents.pokeclaw.widget.MenuGroup
                android:id="@+id/remoteGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- About -->
            <io.agents.pokeclaw.widget.MenuGroup
                android:id="@+id/aboutGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- 通道分组 (hidden) -->
            <io.agents.pokeclaw.widget.MenuGroup
                android:id="@+id/channelGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
